#: nala/options.py:60
msgid "{notice} Unable to read config file: {filename}. Using defaults"
msgstr ""
"{notice} ვერ წავიკითხე კონფიგურაციის ფაილი: {filename}. გამოიყენება "
"ნაგულისხმევი მნიშვნელობები"

#: nala/options.py:73
msgid "{error} Config key '{key}' should be a bool not {value}"
msgstr ""
"{error} კონფიგურაციის გასაღები '{key}' უნდა იყოს ლოგიკური და არა {value}"

#: nala/options.py:350
msgid "{error} Option {option}: Configuration item must have a '='"
msgstr "{error} პარამეტრი {option}: კონფიგურაციის ელემენტს უნდა ჰქონდეს '='"

#: nala/options.py:393
msgid ""
"It seems the system has no license file\n"
"The full GPLv3 can be found at:\n"
"https://www.gnu.org/licenses/gpl-3.0.txt"
msgstr ""
"როგორც ჩანს, სისტემას ლიცენზიის ფაილი არ აქვს\n"
"GPLv3-ის სრული ტექსტი შეგიძლიათ იპოვოთ მისამართზე:\n"
"https://www.gnu.org/licenses/gpl-3.0.txt"

#: nala/options.py:433
msgid "Show program's version number and exit."
msgstr "პროგრამის ვერსიის ნომრის ჩვენება და გასვლა."

#: nala/options.py:441
msgid "Reads the GPLv3 which Nala is licensed under."
msgstr "წაიკითხავს GPLv3-ს, რომლითაც Nala ვრცელდება."

#: nala/options.py:450
msgid "Disable scrolling text and print extra information."
msgstr "ტექსტის გადახვევის გამორთვა და დამატებითი ინფორმაციის გამოტანა."

#: nala/options.py:458
msgid "Logs extra information for debugging."
msgstr "ჟურნალში ჩაწერს გამართვისთვის საჭირო დამატებით ინფორმაციას."

#: nala/options.py:466
msgid "Toggle autoremoving packages."
msgstr "პაკეტების ავტოწაშლის გადართვა."

#: nala/options.py:473
msgid "Toggle installing recommended packages."
msgstr "რეკომენდებული პაკეტების დაყენების გადართვა."

#: nala/options.py:480
msgid "Toggle installing suggested packages."
msgstr "ნარჩევი პაკეტების დაყენების გადართვა."

#: nala/options.py:488
msgid "Set the default release to install packages from."
msgstr "ნაგულისხმევი გამოცემის დაყენება პაკეტების იქიდან დასაყენებლად."

#: nala/options.py:495
msgid "Toggle full-upgrade"
msgstr "სრული განახლების გადართვა"

#: nala/options.py:502
msgid "Force color or no color."
msgstr "ნაძალადევი ფერადობა, ან შავთეთრობა."

#: nala/options.py:508
msgid "Toggle updating the package list."
msgstr "პაკეტების სიის განახლების გადართვა."

#: nala/options.py:515
msgid "Toggle a more condensed transaction summary."
msgstr "უფრო შემჭიდროვებული ტრანზაქციის შეჯამების გადართვა."

#: nala/options.py:523
msgid "Purge any packages that would be removed."
msgstr "ყველა წაშლადი პაკეტის მოსუფთავება."

#: nala/options.py:529
msgid "Purge packages not installed that have config files."
msgstr ""
"პაკეტების მოსუფთავება, რომლებიც დაყენებული არაა, მაგრამ აქვს კონფიგურაციის "
"ფაილები."

#: nala/options.py:537
msgid "Allow the removal of essential packages."
msgstr "ძირითადი პაკეტების წაშლის დაშვება."

#: nala/options.py:546
msgid "Toggle fix broken packages."
msgstr "გაფუჭებული პაკეტების გასწორების გადართვა."

#: nala/options.py:555
msgid "Assume 'yes' or 'no' to all prompts."
msgstr "'დიახის' ან 'არას' პასუხი ყველა კითხვაზე."

#: nala/options.py:564
msgid "Set options like Dpkg::Options::=\"--force-confnew\"."
msgstr "დააყენეთ პარამეტრები, როგორიცაა Dpkg::Options::=\"--force-confnew\"."

#: nala/options.py:572
msgid "Skips all formatting and you get raw dpkg output."
msgstr ""
"გამოტოვებს ყველა დაფორმატებას და თქვენ მიიღებთ dpkg-ის დაუმუშავებელ "
"ინფორმაციას."

#: nala/options.py:581
msgid "Show all versions of a package."
msgstr "პაკეტის ყველა ვერსიის ჩვენება."

#: nala/options.py:590
msgid "Show all architectures of a package."
msgstr "პაკეტის ყველა არქიტექტურის ჩვენება."

#: nala/options.py:599
msgid "Packages are only retrieved, not unpacked or installed."
msgstr "ხდება პაკეტების, მხოლოდ, მიღება, მაგრამ არა გაშლა, ან დაყენება."

#: nala/options.py:608
msgid "Search only package names."
msgstr "მხოლოდ, პაკეტის სახელების ძებნა."

#: nala/options.py:617
msgid "Only installed packages."
msgstr "მხოლოდ დაყენებული პაკეტები."

#: nala/options.py:625
msgid "Only packages explicitly installed with Nala."
msgstr "მხოლოდ Nala-ით დაყენებული პაკეტები."

#: nala/options.py:634
msgid "Only upgradable packages."
msgstr "მხოლოდ, განახლებადი პაკეტები."

#: nala/options.py:651
msgid "Only virtual packages."
msgstr "მხოლოდ ვირტუალური პაკეტები."

#: nala/options.py:659
msgid "Print the full description of each package."
msgstr "თითოეული პაკეტის სრული აღწერის გამოტანა."

#: nala/options.py:665
msgid "Remove package lists located in `/var/lib/apt/lists/`."
msgstr "Remove package lists located in `/var/lib/apt/lists/`."

#: nala/options.py:671
msgid "Remove `nala-sources.list`."
msgstr "`nala-sources.list`-ის წაშლა."

#: nala/options.py:675
msgid "Run fetch uninteractively. Will still prompt for overwrite"
msgstr "გამოთხოვის არაინტერაქტიულად გაშვება. თავზე გადაწერას გკითხავთ"

#: nala/options.py:684
msgid "Show this message and exit."
msgstr "ამ შეტყობინების ჩვენება და გასვლა."

#. Answers for the Question prompt "[Y/n]"
#: nala/utils.py:66
msgid "Y/y N/n"
msgstr "Y/y N/n"

#: nala/utils.py:128
msgid "Terminal can't support dialog, falling back to readline"
msgstr "ტერმინალს დიალოგის მხარდაჭერა არ აქვს. გადავერთვები readline-ზე"

#: nala/utils.py:313
msgid ""
"{command} is not a command\n"
"Did you mean {correction}?"
msgstr ""
"{command} ბრძანება არაა\n"
"გულისხმობდით ბრძანებას {correction}?"

#: nala/utils.py:346
msgid ""
"{error} Some packages are unable to be authenticated. Use '-o "
"APT::Get::AllowUnauthenticated=true' with `--yes`"
msgstr ""
"{error} ზოგიერთი პაკეტის ავთენტიკაცია შეუძლებელია. გამოიყენეთ '-o "
"APT::Get::AllowUnauthenticated=true' და `--yes`"

#: nala/utils.py:361
msgid "{error} failed regex compilation '{error_msg} at position {position}'"
msgstr ""
"{error} რეგგამოსის კომპილაცია ჩავარდა '{error_msg} პოზიციასთან {position}'"

#: nala/utils.py:372
msgid "{error} Nala needs root to fix broken packages"
msgstr "{error} Nala-ს გაფუჭებული პაკეტების გასასწორებლად root სჭირდება"

#: nala/utils.py:377
msgid "{error} Nala needs root to {command}"
msgstr "{error} Nala-ს სჭირდება root ბრძანებისთვის {command}"

#: nala/utils.py:402
msgid "{error} Nala is already running another instance {last_pid}"
msgstr "{error} Nala-ის სხვა ასლი უკვე გაშვებულია {last_pid}"

#: nala/utils.py:438
msgid "Removing files in {dir}"
msgstr "იშლება ფაილები საქარალდეში {dir}"

#: nala/utils.py:441
msgid "Removed: {filename}"
msgstr "წაიშალა: {filename}"

#: nala/utils.py:459 nala/utils.py:477
msgid "{error} can't find version for {package}"
msgstr "{error} ვერ ვიპოვე ვერსია პაკეტისთვის {package}"

#: nala/__main__.py:44
msgid "Exiting at your request."
msgstr "გასვლა თქვენი მოთხოვნით."

#: nala/__main__.py:50
msgid "{error} No space left on device."
msgstr "{error} მოწყობილობაზე ადგილი აღარ დარჩა."

#. The following are the headers for the transaction summary.
#. Package:        Version:     Size:
#. ansible-core    2.12.4-1    1.2 MB
#: nala/summary.py:39
msgid "Package/Version/Size/Old Version/New Version/Either"
msgstr "პაკეტი/ვერსია/ზომა/ძველი ვერსია/ახალი ვერსია/ან"

#. Verb Tenses are [ "Present/Present Participle/Past" ]
#. This ends up looking like [ "Auto-Purge 20 Packages" ]
#: nala/summary.py:44
msgid "Auto-Purge/Auto-Purging/Auto-Purged"
msgstr "ავტოგასუფთავება/მიმდინარეობს ავტოგასუფთავება/ავტოგასუფთავებულია"

#. Verb Tenses are [ "Present/Present Participle/Past" ]
#. This ends up looking like [ "Auto-Remove 20 Packages" ]
#: nala/summary.py:49
msgid "Auto-Remove/Auto-Removing/Auto-Removed"
msgstr "ავტოწაშლა/მიმდინარეობს ავტოწაშლა/ავტოწაშლილია"

#. Verb Tenses are [ "Present/Present Participle/Past" ]
#. This ends up looking like [ "Remove 20 Packages" ]
#: nala/summary.py:54
msgid "Remove/Removing/Removed"
msgstr "წაშლა/იშლება/წაიშალა"

#. Verb Tenses are [ "Present/Present Participle/Past" ]
#. This ends up looking like [ "Purge 20 Packages" ]
#: nala/summary.py:59
msgid "Purge/Purging/Purged"
msgstr "გასუფთავება/სუფთავდება/გასუფთავდა"

#. Verb Tenses are [ "Present/Present Participle/Past" ]
#. This ends up looking like [ "Install 20 Packages" ]
#: nala/summary.py:64
msgid "Install/Installing/Installed"
msgstr "დაყენება/მიმდინარეობს დაყენება/დაყენებულია"

#. Verb Tenses are [ "Present/Present Participle/Past" ]
#. This ends up looking like [ "Reinstall 20 Packages" ]
#: nala/summary.py:69
msgid "Reinstall/Reinstalling/Reinstalled"
msgstr "თავიდან დაყენება/მიმდინარეობს თავიდან დაყენება/თავიდან დაყენებულია"

#. Verb Tenses are [ "Present/Present Participle/Past" ]
#. This ends up looking like [ "Upgrade 20 Packages" ]
#: nala/summary.py:74
msgid "Upgrade/Upgrading/Upgraded"
msgstr "განახლება/მიმდინარეობს განახლება/განახლებულია"

#. Verb Tenses are [ "Present/Present Participle/Past" ]
#. This ends up looking like [ "Downgrade 20 Packages" ]
#: nala/summary.py:79
msgid "Downgrade/Downgrading/Downgraded"
msgstr "ვერსიის დაწევა/მიმდინარეობს ვერსიის დაწევა/ვერსია დაწეულია"

#. Verb Tenses are [ "Present/Present Participle/Past" ]
#. This ends up looking like [ "Configure 20 Packages" ]
#: nala/summary.py:84
msgid "Configure/Configuring/Configured"
msgstr "მორგება/მიმდინარეობს მორგება/მორგებულია"

#: nala/summary.py:276 nala/summary.py:295
msgid "Recommended, Will Not Be Installed"
msgstr "რეკომენდებულია. დაყენებული არ იქნება"

#: nala/summary.py:277 nala/summary.py:299
msgid "Suggested, Will Not Be Installed"
msgstr "ნარჩევია. დაყენებული არ იქნება"

#: nala/summary.py:279 nala/summary.py:297
msgid "Kept Back, Will Not Be Upgraded"
msgstr "შენარჩუნებულია. არ განახლდება"

#: nala/summary.py:279 nala/summary.py:297
msgid "Kept Back"
msgstr "შესანარჩუნებელია"

#: nala/summary.py:281
msgid "Auto-Removable, Will Not Be Removed"
msgstr "ავტოწაშლადი. არ წაიშლება"

#: nala/summary.py:373 nala/summary.py:484
msgid "Summary"
msgstr "შეჯამება"

#. This ends up looking like [ "Configure 20 Packages" ]
#: nala/summary.py:386
msgid "Packages"
msgstr "პაკეტები"

#: nala/summary.py:397 nala/summary.py:490
msgid "Total download size"
msgstr "ჩამოტვირთვის სრული ზომა"

#: nala/summary.py:399 nala/summary.py:492
msgid "Disk space to free"
msgstr "გასათავისუფლებელი ადგილი დისკზე"

#: nala/summary.py:401 nala/summary.py:494
msgid "Disk space required"
msgstr "აუცილებელი ადგილი დისკზე"

#: nala/summary.py:405 nala/summary.py:498
msgid "Nala will only download the packages"
msgstr "Nala მხოლოდ გადმოწერს პაკეტებს"

#: nala/install.py:129
msgid "Purging configuration files for {package}"
msgstr "კონფიგურაციის ფაილების მოსუფთავება პაკეტისთვის {package}"

#: nala/install.py:209
msgid "{notice} Selected packages cannot be excluded from upgrade safely."
msgstr "{notice} არჩეული პაკეტების განახლებიდან უსაფრთხოდ ამოღება შეუძლებელია."

#: nala/install.py:231
msgid "{error} Unable to calculate how to protect the selected packages"
msgstr ""
"{error} გამოთვლა, როგორ უნდა იქნეს არჩეული პაკეტების დაცვა, შეუძლებელია"

#: nala/error.py:581 nala/install.py:235 nala/nala.py:307
msgid "{error} You have held broken packages"
msgstr "{error} თქვენ გაქვთ შენარჩუნებული გაფუჭებული პაკეტები"

#: nala/install.py:237
msgid "{notice} The following packages need to be protected as well:"
msgstr "{notice} ასევე მოხდება შემდეგი პაკეტების დაცვა:"

#: nala/install.py:431
msgid "Log Started: [{date}]"
msgstr "ჟურნალის დასაწყისი: [{date}]"

#: nala/install.py:445
msgid "Log Ended: [{date}]"
msgstr "ჟურნალის დასასრული: [{date}]"

#: nala/install.py:508
msgid "{error} Fetching packages has failed!"
msgstr "{error} პაკეტის გამოთხოვა ჩავარდა!"

#: nala/install.py:511 nala/install.py:1179
msgid "Exiting due to SIGINT"
msgstr "მივიღე SIGINT. გასვლა"

#: nala/install.py:522
msgid "{notice} A reboot is required."
msgstr "{notice} საჭიროა გადატვირთვა."

#: nala/install.py:523
msgid "Finished Successfully"
msgstr "წარმატებით დასრულდა"

#: nala/install.py:600
msgid "{notice} The following will be installed to satisfy {package}:"
msgstr ""
"{notice} {package}-ის დასაკმაყოფილებლად მოხდება შემდეგი პაკეტების დაყენება:"

#: nala/install.py:643
msgid ""
"{notice} Newer version {package} {version} exists in the cache.\n"
"You should consider using `{command}`"
msgstr ""
"{notice} კეშში არსებობს უფრო ახალი ვერსია {package} {version}.\n"
"უნდა იყენებდეთ ბრძანებას `{command}`"

#: nala/install.py:686
msgid "{notice} {deb} has taken priority over {package} from the cache."
msgstr ""
"{notice} {deb}-ს აქვს უფრო მაღალი პრიორიეტეტი, ვიდრე პაკეტს {package} "
"კეშიდან."

#: nala/downloader.py:250 nala/install.py:706
msgid ""
"{error} No content length in response from {url}\n"
"  Ensure the URL points to a Debian Package"
msgstr ""
"{error} {url}-ის პასუხში შემცველობის სიგრძე მითითებული არაა\n"
"  დარწმუნდით, რომ ბმული Debian-ის პაკეტზე მიუთითებს"

#: nala/install.py:742
msgid "{notice} {filename} can't be hashsum verified."
msgstr "{notice} {filename}-ის ჰეშის ჯამის გადათვლა შეუძლებელია."

#: nala/install.py:747 nala/install.py:1220
msgid "Do you want to continue?"
msgstr "გნებავთ, გააგრძელოთ?"

#: nala/fetch.py:904 nala/install.py:748 nala/install.py:1221
msgid "Abort."
msgstr "შეწყვეტა."

#: nala/install.py:791
msgid "{error} Hash does not match the '{hash_type}' Length"
msgstr "{error} ჰეში '{hash_type}'-ის სიგრძეს არ ემთხვევა"

#: nala/install.py:798
msgid "{error} Hash Type '{hash_type}' specified with no hash"
msgstr ""
"{error} მითითებულია ჰეშის ტიპი'{hash_type}', მაგრამ ჰეში აღმოჩენილი არაა"

#: nala/install.py:805
msgid "{error} Hash Type '{hash_type}' is unsupported"
